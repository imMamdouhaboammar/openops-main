    "integration_patterns": {
      "dataFlow": [
        "Traffic Source → Google Analytics 4 → Segment → Data Warehouse",
        "User Behavior → Mixpanel/Amplitude → BI Tool → Dashboards",
        "Customer Interaction → CRM → Marketing Automation → Email Marketing",
        "Campaign Performance → Ad Platform → Analytics → Attribution Model"
      ],
      "workflowExamples": [
        {
          "workflow": "Email Campaign to Conversion",
          "steps": [
            "1. Segment audience in HubSpot",
            "2. Design and send campaign in Mailchimp",
            "3. Track opens/clicks in Mailchimp",
            "4. Sync to HubSpot CRM",
            "5. Track conversions in GA4",
            "6. Analyze in Segment/warehouse"
          ]
        },
        {
          "workflow": "Paid Ad Optimization Loop",
          "steps": [
            "1. Run ads in Google Ads/Facebook",
            "2. Track conversions via pixel",
            "3. Measure in GA4",
            "4. Analyze in Segment",
            "5. A/B test variants in VWO",
            "6. Scale winners, pause losers"
          ]
        }
