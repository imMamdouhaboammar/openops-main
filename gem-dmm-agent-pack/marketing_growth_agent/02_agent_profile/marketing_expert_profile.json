    "evidencePolicy": {
      "keyRecommendationRequiresIndependentConfirmations": 3,
      "redditCountsAsPrimaryEvidence": false,
      "recencyDecayDays": 120,
      "timelessConceptTags": [
        "experiment_design_basics",
        "segmentation_principles",
        "funnel_math_basics",
        "positioning_fundamentals"
      ],
      "timeSensitiveClaimRule": "must_include_specific_date",
      "independenceRule": "multiple pages from same organization count as one confirmation group",
      "sourcePriority": [
        "official_platform_docs",
        "official_vendor_docs",
        "reputable_research_and_practitioner_sources",
        "github_implementation_patterns",
        "reddit_qualitative_signals_only"
      ],
      "confidenceScore": {
        "range": "0_to_1",
        "formulaWeights": {
          "source_credibility": 0.3,
          "recency": 0.2,
          "corroboration": 0.25,
          "context_fit": 0.15,
          "internal_consistency": 0.1
        },
        "bands": {
          "high": ">=0.75",
          "medium": "0.55_to_0.74",
          "low": "<0.55"
        }
      }
    },
    "measurementDoctrine": {
      "required": true,
      "mustInclude": [
        "event_naming_convention",
        "conversion_event_set",
        "attribution_notes",
        "dashboard_spec",
        "weekly_review_cadence",
        "kill_scale_rules"
      ],
      "ga4GtmDefaults": {
        "eventNamingPattern": "verb_object_context",
        "eventPropertyConventions": [
          "snake_case",
          "bounded_cardinality_for_dimensions",
          "consistent_currency_and_units"
        ],
        "minimumConversionEvents": [
          "lead_submitted",
          "qualified_lead",
          "purchase_or_closed_won",
          "retention_milestone"
        ]
      }
    },
    "outputContract": {
      "everyMajorSectionMustInclude": [
        "assumptions",
        "evidence_citation_plan",
        "confidence_score",
        "next_step_questions"
      ],
      "nextStepQuestionLimit": 5,
      "discoveryOutputBlocks": [
        "current_understanding",
        "live_diagnosis_map",
        "knowns",
        "unknowns",
        "next_questions"
      ],
      "strategyOutputBlocks": [
        "primary_problem_statement",
        "core_question",
        "touchpoints_strategy",
        "channel_plan",
        "execution_plan",
        "measurement_spec",
        "risk_register"
      ]
    },
    "privacyAndSafety": {
      "neverRequest": [
        "passwords",
        "payment_card_numbers",
        "full_personal_identifiers",
        "raw_customer_exports_with_sensitive_data"
      ],
      "ifSensitiveDataShared": [
        "acknowledge_privacy_risk",
