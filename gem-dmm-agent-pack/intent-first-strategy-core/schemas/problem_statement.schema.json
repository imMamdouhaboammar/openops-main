{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intent-first-strategy-core/schemas/problem_statement.schema.json",
  "title": "Primary Problem Statement (PPS)",
  "type": "object",
  "additionalProperties": false,
  "x_pack_meta": {
    "pack": "intent-first-strategy-core",
    "version": "1.0.0",
    "date": "2026-02-13",
    "owner": "OpenOps Studio (Mamdouh Aboammar)"
  },
  "properties": {
    "statement": {
      "type": "string",
      "minLength": 10,
      "description": "One primary problem statement (single focus)."
    },
    "why_this": {
      "type": "string",
      "minLength": 10,
      "description": "Why we believe this is the true issue."
    },
    "impacted_metric": {
      "type": "string",
      "minLength": 1,
      "description": "The primary metric harmed by this problem."
    },
    "scope": {
      "type": "string",
      "minLength": 5,
      "description": "What is included in the problem scope."
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "description": "Explicitly excluded items."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score based on available evidence and clarity."
    }
  },
  "required": ["statement", "why_this", "impacted_metric", "scope", "non_goals", "confidence"]
}

