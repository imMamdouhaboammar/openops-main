{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gem-dmm-agent-pack/schemas/experiment_schema.json",
  "title": "Experiment Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "created_at": { "type": "string", "format": "date" }
      },
      "required": ["schema_version", "created_at"]
    },
    "experiment_id": { "type": "string", "minLength": 3 },
    "name": { "type": "string", "minLength": 5 },
    "hypothesis": { "type": "string", "minLength": 10 },
    "variants": { "type": "array", "items": { "type": "string", "minLength": 2 }, "minItems": 2 },
    "primary_metric": { "type": "string", "minLength": 1 },
    "guardrails": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "minimum_runtime_days": { "type": "integer", "minimum": 3, "maximum": 90 },
    "decision_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kill": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "iterate": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "scale": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "required": ["kill", "iterate", "scale"]
    },
    "status": { "type": "string", "enum": ["draft", "running", "paused", "completed", "killed"] }
  },
  "required": [
    "_meta",
    "experiment_id",
    "name",
    "hypothesis",
    "variants",
    "primary_metric",
    "guardrails",
    "minimum_runtime_days",
    "decision_rules",
    "status"
  ]
}

