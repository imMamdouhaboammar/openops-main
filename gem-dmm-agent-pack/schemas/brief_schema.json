{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gem-dmm-agent-pack/schemas/brief_schema.json",
  "title": "Normalized Marketing Brief Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "created_at": { "type": "string", "format": "date" },
        "source": { "type": "string", "enum": ["user_intake", "agent_discovery"] }
      },
      "required": ["schema_version", "created_at", "source"]
    },
    "business_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "business_model": { "type": "string" },
        "industry": { "type": "string" },
        "geographies": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "value_proposition": { "type": "string" },
        "pricing_model": { "type": "string" }
      },
      "required": ["business_model", "industry", "geographies", "languages", "value_proposition", "pricing_model"]
    },
    "icp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_icp": { "type": "string", "minLength": 3 },
        "secondary_segments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["primary_icp"]
    },
    "goals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "core_outcome": { "type": "string" },
        "primary_metric": { "type": "string" },
        "time_horizon_days": { "type": "integer", "minimum": 7, "maximum": 365 }
      },
      "required": ["core_outcome", "primary_metric", "time_horizon_days"]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "monthly_budget_range": { "type": "string" },
        "team_capacity_hours_per_week": { "type": "integer", "minimum": 0, "maximum": 500 },
        "non_negotiables": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["monthly_budget_range"]
    },
    "funnel_baseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "awareness": { "type": "object", "additionalProperties": { "type": "string" } },
        "acquisition": { "type": "object", "additionalProperties": { "type": "string" } },
        "activation": { "type": "object", "additionalProperties": { "type": "string" } },
        "retention": { "type": "object", "additionalProperties": { "type": "string" } },
        "revenue": { "type": "object", "additionalProperties": { "type": "string" } },
        "referral": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "current_marketing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "active_channels": { "type": "array", "items": { "type": "string" } },
        "tracking_stack": { "type": "array", "items": { "type": "string" } },
        "known_issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "regional_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_country": { "type": "string" },
        "secondary_countries": { "type": "array", "items": { "type": "string" } },
        "primary_city": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "currency": { "type": "string" },
        "seasonality_notes": { "type": "string" },
        "local_compliance_notes": { "type": "string" }
      }
    },
    "data_availability_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "available": { "type": "array", "items": { "type": "string" } },
        "missing": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      },
      "required": ["available", "missing"]
    }
  },
  "required": ["_meta", "business_snapshot", "icp", "goals", "constraints", "data_availability_map"]
}
