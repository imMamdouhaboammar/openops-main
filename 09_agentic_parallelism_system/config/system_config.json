{
  "system": {
    "name": "AgenticParallelismSystem",
    "version": "1.0.0",
    "description": "14 Key Patterns for Agentic AI with Parallelism & Optimization",
    "environment": "production"
  },
  "performance": {
    "enable_monitoring": true,
    "enable_profiling": true,
    "enable_caching": true,
    "cache_ttl_seconds": 3600,
    "max_parallel_tasks": 10,
    "timeout_seconds": 30,
    "retry_attempts": 3
  },
  "parallelism": {
    "default_executor": "asyncio",
    "max_workers": 5,
    "enable_speculation": true,
    "enable_redundancy": false,
    "redundancy_factor": 2
  },
  "reliability": {
    "enable_error_detection": true,
    "enable_fault_tolerance": true,
    "enable_graceful_degradation": true,
    "consensus_threshold": 0.8
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "enable_performance_logs": true,
    "enable_audit_logs": true
  },
  "integrations": {
    "openops": {
      "enabled": true,
      "orchestrator_url": "http://localhost:8000",
      "api_key": "${OPENOPS_API_KEY}"
    },
    "langgraph": {
      "enabled": true,
      "checkpointing": true
    }
  }
}
