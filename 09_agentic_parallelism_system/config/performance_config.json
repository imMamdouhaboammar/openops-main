{
  "metrics": {
    "latency": {
      "enabled": true,
      "track_total": true,
      "track_per_component": true,
      "track_percentiles": [50, 90, 95, 99],
      "alert_threshold_ms": 5000
    },
    "throughput": {
      "enabled": true,
      "window_seconds": 60,
      "target_tps": 100
    },
    "memory": {
      "enabled": true,
      "sample_interval_seconds": 10,
      "alert_threshold_mb": 1000
    },
    "network": {
      "enabled": true,
      "track_api_calls": true,
      "track_data_transfer": true
    },
    "quality": {
      "enabled": true,
      "metrics": ["accuracy", "relevance", "completeness", "coherence"],
      "minimum_score": 0.7
    }
  },
  "benchmarks": {
    "parallel_tool_use": {
      "baseline_latency_ms": 3000,
      "target_improvement_percent": 50
    },
    "hypothesis_generation": {
      "baseline_quality_score": 0.7,
      "target_improvement_percent": 30
    },
    "competitive_ensemble": {
      "baseline_quality_score": 0.75,
      "target_improvement_percent": 20
    }
  },
  "optimization": {
    "auto_tune": true,
    "tune_interval_hours": 24,
    "parameters": ["parallel_workers", "cache_ttl", "timeout"],
    "objective": "minimize_latency_maximize_quality"
  },
  "reporting": {
    "interval_minutes": 5,
    "export_format": "json",
    "export_path": "./performance_reports/",
    "dashboards": {
      "realtime": true,
      "historical": true,
      "comparative": true
    }
  }
}
