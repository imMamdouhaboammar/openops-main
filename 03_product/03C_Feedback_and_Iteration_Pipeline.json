{
  "module": {
    "name": "Feedback_and_Iteration_Pipeline",
    "version": "2.0.0",
    "layer": "03_product",
    "code": "03C",
    "description": "Manages user feedback collection, prioritization, and iteration cycles",
    "author": "OpenOps Foundation",
    "created": "2025-12-16T00:00:00Z"
  },
  "governance": {
    "compliance_level": "standard",
    "requires_approval": false,
    "audit_level": "standard",
    "data_classification": "internal",
    "retention_policy": "3_years"
  },
  "objectives": [
    "Collect and categorize user feedback",
    "Prioritize iteration cycles",
    "Track feedback-to-feature conversion",
    "Enable continuous improvement"
  ],
  "integration_points": {
    "imports_from": ["03A_PRD_Template_Generator.json", "07A_Analytics_Event_Schema.json"],
    "exports_to": ["03B_ProductTracker_and_Roadmap.json", "00B_OpenOps_Audit_and_Decision_Ledger.json"]
  },
  "security_rules": {
    "pii_handling": "anonymize",
    "feedback_access": "product_team_only"
  },
  "feedback_channels": {
    "in_app": {"enabled": true, "sampling_rate": 0.05},
    "support_tickets": {"enabled": true, "auto_categorize": true},
    "user_interviews": {"enabled": true, "recording_consent_required": true},
    "surveys": {"enabled": true, "max_frequency": "monthly"}
  },
  "prioritization_framework": {
    "criteria": {
      "user_impact": {"weight": 0.35},
      "business_value": {"weight": 0.30},
      "implementation_effort": {"weight": 0.20},
      "strategic_alignment": {"weight": 0.15}
    }
  },
  "version_history": {"2.0.0": {"date": "2025-12-16", "changes": "Initial feedback pipeline"}}
}
