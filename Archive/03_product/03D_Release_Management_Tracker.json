{
  "module": {
    "name": "Release_Management_Tracker",
    "version": "2.0.0",
    "layer": "03_product",
    "code": "03D",
    "description": "Tracks release cycles, deployment status, and rollback procedures",
    "author": "OpenOps Foundation",
    "created": "2025-12-16T00:00:00Z"
  },
  "governance": {
    "compliance_level": "high",
    "requires_approval": true,
    "audit_level": "full",
    "data_classification": "confidential"
  },
  "objectives": [
    "Manage release schedules",
    "Track deployment status",
    "Monitor release health",
    "Enable quick rollbacks"
  ],
  "integration_points": {
    "imports_from": ["03B_ProductTracker_and_Roadmap.json", "06B_Access_Control_and_Encryption.json"],
    "exports_to": ["00B_OpenOps_Audit_and_Decision_Ledger.json", "07A_Analytics_Event_Schema.json"]
  },
  "release_types": {
    "major": {"frequency": "quarterly", "approval": "executive"},
    "minor": {"frequency": "monthly", "approval": "product_manager"},
    "patch": {"frequency": "weekly", "approval": "team_lead"},
    "hotfix": {"frequency": "as_needed", "approval": "on_call_engineer"}
  },
  "deployment_gates": {
    "automated_tests": {"pass_rate": 0.98},
    "security_scan": {"critical_issues": 0},
    "performance_benchmarks": {"regression_threshold": 0.05},
    "qa_signoff": {"required": true}
  },
  "version_history": {"2.0.0": {"date": "2025-12-16", "changes": "Initial release management"}}
}
