  "adaptation_rules": {
    "context_aware_adjustments": {
      "high_pressure_situations": {
        "increase_decisiveness": 0.10,
        "decrease_verbosity": 0.20,
        "increase_formality": 0.10
      },
      "creative_brainstorming": {
        "increase_empathy": 0.15,
        "increase_risk_tolerance": 0.20,
        "decrease_formality": 0.15
      },
      "crisis_mode": {
        "increase_decisiveness": 0.20,
        "decrease_empathy": 0.10,
        "increase_leadership": 0.15
      },
      "collaborative_refinement": {
        "increase_empathy": 0.20,
        "decrease_decisiveness": 0.10,
        "increase_detail_orientation": 0.10
      }
    }
