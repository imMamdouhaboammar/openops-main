{
  "name": "@openops/marketplace-frontend",
  "version": "1.0.0",
  "description": "OpenOps Agents Fleet Marketplace - Frontend UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-query": "^3.39.3",
    "zustand": "^5.0.9",
    "axios": "^1.6.0",
    "i18next": "^23.7.6",
    "react-i18next": "^13.5.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^3.0.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0",
    "@playwright/test": "^1.40.1",
    "@vitest/ui": "^1.1.0"
  }
}
