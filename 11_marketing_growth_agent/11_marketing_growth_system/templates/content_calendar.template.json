  "content_production_workflow": {
    "roles_and_responsibilities": {
      "content_strategist": "Plans calendar, ensures alignment with campaign objectives",
      "writers": "Create blog posts, email copy, social copy",
      "designers": "Create images, graphics, infographics",
      "video_producers": "Script, film, edit video content",
      "social_media_manager": "Schedule and publish social content, engage with audience",
      "marketing_ops": "Set up tracking, manage distribution tools, report on performance"
    },
    
    "production_stages": {
      "ideation": "Week W-4: Brainstorm topics, align with campaign strategy",
      "planning": "Week W-3: Finalize calendar, assign owners, set deadlines",
      "production": "Week W-2 to W: Create drafts, design assets, produce videos",
      "review": "Week W-1: Review all content, gather feedback, revise",
      "approval": "Week W-1: Final approval from stakeholders",
      "publication": "Week W: Publish according to calendar",
      "promotion": "Week W to W+1: Promote content across channels",
      "analysis": "Week W+1: Measure performance, document learnings"
    },
    
