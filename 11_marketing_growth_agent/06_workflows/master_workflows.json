      {
        "workflowId": "WORKFLOW-001",
        "name": "Growth Strategy Development Workflow",
        "description": "Comprehensive workflow for developing multi-channel growth strategy",
        "complexity": "Complex",
        "duration": "2-4 weeks",
        "stages": [
          {
            "stageNum": 1,
            "stageName": "Market Analysis & Opportunity Assessment",
            "duration": "3-5 days",
            "activities": [
              "Define TAM, SAM, SOM",
              "Analyze competitive landscape",
              "Identify target customer segments",
              "Assess market growth trends",
              "Calculate addressable market"
            ],
            "outputs": [
              "Market opportunity document",
              "Competitive positioning matrix",
              "Target customer segments definition"
            ]
          },
          {
            "stageNum": 2,
            "stageName": "Customer Research & Persona Development",
            "duration": "1-2 weeks",
            "activities": [
              "Conduct customer interviews (15-20)",
              "Develop customer personas (3-5)",
              "Map customer journeys",
              "Identify key pain points and jobs",
              "Define messaging for each persona"
            ],
            "outputs": [
              "Customer persona documents",
              "Customer journey maps",
              "Job-to-be-done analysis"
            ]
          },
          {
            "stageNum": 3,
            "stageName": "Channel Strategy & Tactic Selection",
            "duration": "1 week",
            "activities": [
              "Score channels by (impact, cost, speed)",
              "Select primary channels (2-4)",
              "Develop channel-specific tactics",
              "Estimate CAC and LTV by channel",
              "Create channel roadmap"
            ],
            "outputs": [
              "Channel selection rationale",
              "Channel-specific tactics",
              "Channel roadmap with milestones"
            ]
          },
          {
            "stageNum": 4,
            "stageName": "90-Day Growth Plan Development",
            "duration": "1 week",
            "activities": [
              "Set growth targets (revenue, users, engagement)",
              "Develop monthly initiatives",
              "Identify dependencies and risks",
              "Allocate budget and resources",
              "Create success metrics"
            ],
            "outputs": [
              "90-day growth plan",
              "Budget allocation",
              "KPI tracking dashboard"
            ]
          }
        ],
        "successCriteria": [
          "Growth plan is data-backed and realistic",
          "Clear owner for each initiative",
          "All key channels represented",
          "Metrics are SMART (Specific, Measurable, Achievable, Relevant, Time-bound)",
          "Team is aligned on strategy"
        ]
      },

      {
        "workflowId": "WORKFLOW-002",
        "name": "Conversion Rate Optimization Workflow",
        "description": "Structured CRO process for maximizing conversion rates",
        "complexity": "Advanced",
        "duration": "6-12 weeks",
        "stages": [
          {
            "stageNum": 1,
            "stageName": "Audit & Baseline Establishment",
            "duration": "1-2 weeks",
            "activities": [
              "Map complete conversion funnel",
              "Analyze dropout rates by stage",
              "Identify bottlenecks (>20% drop-off)",
              "Segment by traffic source and user type",
              "Establish baseline conversion rate"
            ],
            "outputs": [
              "Funnel map with drop-off rates",
              "Bottleneck prioritization matrix",
              "Baseline metrics"
            ]
          },
          {
            "stageNum": 2,
            "stageName": "Research & Hypothesis Generation",
            "duration": "1-2 weeks",
            "activities": [
              "Conduct heatmap and session recording analysis",
              "Review user feedback and support tickets",
              "Apply conversion psychology principles",
              "Analyze competitor solutions",
              "Generate 15-20 high-potential hypotheses"
            ],
            "outputs": [
              "Hypothesis priority matrix",
              "Psychological principles applied",
              "Expected impact estimates"
            ]
          },
          {
            "stageNum": 3,
            "stageName": "Testing & Experimentation",
            "duration": "3-8 weeks",
            "activities": [
              "Design A/B tests for top 5 hypotheses",
              "Validate statistical power requirements",
              "Execute tests (minimum 1-2 weeks each)",
              "Analyze results with proper statistics",
              "Document learnings"
            ],
            "outputs": [
              "Test results (winners and learnings)",
              "Statistical analysis reports",
              "Tested variations catalog"
            ]
          },
          {
            "stageNum": 4,
            "stageName": "Implementation & Scaling",
            "duration": "1-2 weeks",
            "activities": [
              "Roll out winning variants",
              "Monitor for secondary effects",
              "Measure impact at scale",
              "Plan next round of tests",
              "Share learnings with team"
            ],
            "outputs": [
              "Scaled winning variants",
              "Updated conversion rate baseline",
              "Next test priorities"
            ]
          }
        ],
        "successCriteria": [
          "Conversion rate improved by minimum 10-15%",
          "Learnings documented for future iterations",
          "Scaling plan is clear",
          "Team understands psychological principles applied"
        ]
      },

