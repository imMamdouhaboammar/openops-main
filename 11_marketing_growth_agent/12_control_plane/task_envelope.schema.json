{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openops://11_marketing_growth_agent/12_control_plane/task_envelope.schema.json",
  "title": "Supervisor Task Envelope (Canonical)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelopeVersion",
    "taskId",
    "mode",
    "podId",
    "authorization",
    "objective",
    "inputs",
    "constraints",
    "expectedOutputs",
    "qualityGates"
  ],
  "properties": {
    "envelopeVersion": {
      "type": "string",
      "description": "Schema version for the envelope payload.",
      "examples": ["1.0.0"]
    },
    "taskId": {
      "type": "string",
      "description": "Unique task identifier generated by the Supervisor (stable across retries).",
      "examples": ["TASK-CLINIC-ONBOARDING-0001"]
    },
    "mode": {
      "type": "string",
      "description": "Operating mode selected by the Supervisor.",
      "enum": ["advisor", "operator"]
    },
    "podId": {
      "type": "string",
      "description": "Which pod is authorized to act on this task.",
      "enum": [
        "POD-STRATEGY",
        "POD-CONTENT",
        "POD-CREATIVE",
        "POD-PAID",
        "POD-ANALYTICS",
        "POD-LIFECYCLE"
      ]
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supervisorToken", "expiresAt", "idempotencyKey"],
      "properties": {
        "supervisorToken": {
          "type": "string",
          "description": "Ephemeral token proving the Supervisor authorized this action."
        },
        "expiresAt": {
          "type": "string",
          "description": "ISO8601 timestamp of token expiry.",
          "examples": ["2026-01-24T12:00:00Z"]
        },
        "idempotencyKey": {
          "type": "string",
          "description": "Required for any side-effect actions so retries do not duplicate work.",
          "examples": ["idem-2026-01-24-0001"]
        }
      }
    },
    "objective": {
      "type": "string",
      "description": "One-sentence objective for the pod.",
      "minLength": 10
    },
    "context": {
      "type": "object",
      "description": "Optional context payload (client, vertical, campaign identifiers).",
      "additionalProperties": true
    },
    "inputs": {
      "type": "object",
      "description": "All required inputs (brief, links, assets inventory, constraints).",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deadline", "compliance", "budget", "scope"],
      "properties": {
        "deadline": {
          "type": "string",
          "description": "When the pod must return outputs (ISO8601).",
          "examples": ["2026-01-31T18:00:00Z"]
        },
        "compliance": {
          "type": "object",
          "additionalProperties": true,
          "description": "Compliance constraints (e.g., clinic restrictions)."
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxSpend", "currency"],
          "properties": {
            "maxSpend": { "type": "number", "minimum": 0 },
            "currency": { "type": "string", "examples": ["USD", "SAR", "EGP"] }
          }
        },
        "scope": {
          "type": "object",
          "description": "Explicit in-scope/out-of-scope guardrails to prevent drift.",
          "additionalProperties": true
        }
      }
    },
    "expectedOutputs": {
      "type": "array",
      "description": "List of artifact types the pod must return.",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "qualityGates": {
      "type": "array",
      "description": "Checkpoints the Supervisor will validate before accepting outputs.",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "approvalGates": {
      "type": "array",
      "description": "Optional approval gates requiring explicit client/lead approval.",
      "items": { "type": "string" }
    },
    "returnFormat": {
      "type": "string",
      "description": "How the pod should return results.",
      "enum": ["artifact_only", "artifact_plus_summary", "artifact_plus_decisions"]
    }
  }
}

