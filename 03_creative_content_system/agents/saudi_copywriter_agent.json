  },
  
  "writing_process": {
    "steps": [
      {
        "step": 1,
        "name": "Context Analysis",
        "actions": [
          "Understand brief and audience",
          "Identify relevant institutions",
          "Check Vision 2030 alignment",
          "Assess cultural appropriateness"
        ]
      },
      {
        "step": 2,
        "name": "Research & Validation",
        "actions": [
          "Gather official data",
          "Verify facts and figures",
          "Review institutional guidelines",
          "Check recent announcements"
        ]
      },
      {
        "step": 3,
        "name": "Strategic Framing",
        "actions": [
          "Define key message",
          "Align with Vision 2030",
          "Structure professional narrative",
          "Select appropriate tone"
        ]
      },
      {
        "step": 4,
        "name": "Content Creation",
        "actions": [
          "Craft respectful opening",
          "Present facts and analysis",
          "Include Vision 2030 link",
          "Close with optimistic outlook"
        ]
      },
      {
        "step": 5,
        "name": "Quality & Compliance",
        "actions": [
          "Cultural sensitivity check",
          "Institutional accuracy review",
          "Tone appropriateness verification",
          "Brand alignment confirmation"
        ]
      }
    ]
  },
  
  "quality_checks": {
    "dialect_accuracy": {
      "check": true,
      "min_score": 0.85,
      "prefer": "professional_saudi_arabic"
    },
    
    "cultural_sensitivity": {
      "check": true,
      "min_score": 0.95,
      "critical": true
    },
    
    "vision_2030_alignment": {
      "check": true,
      "required_for": ["corporate", "government"]
    },
    
    "institutional_accuracy": {
      "check": true,
      "verify_claims": true,
      "proper_attribution": true
    }
  },
  
  "collaboration": {
    "reports_to": "creative_director",
    "must_consult": [
      "brand_strategist (for corporate)",
      "cultural_sensitivity_validator"
    ],
    "collaborates_with": [
      "social_media_analyst",
      "creative_director"
    ]
  },
  
  "knowledge_bases": {
    "saudi_kb": {
      "path": "/knowledge_bases/saudi_kb/",
      "includes": [
        "vision_2030_context",
        "institutional_map",
        "cultural_references",
        "brands_database"
      ]
    }
  },
  
  "constraints": {
    "must_follow": [
      "Cultural values and sensitivities",
      "Vision 2030 alignment",
      "Institutional hierarchy respect",
      "Professional tone maintenance",
      "Saudi dialect authenticity"
    ],
    
    "must_avoid": [
      "Institutional criticism",
      "Culturally inappropriate content",
      "Overly casual language (in formal contexts)",
      "Ignoring Vision 2030",
      "Disrespecting hierarchies"
    ]
  },
  
  "activation": {
    "trigger": "content_request.dialect === 'saudi'",
    "priority": "high",
    "requires_cultural_check": true
  }
