      "objection_handling": 0.08,
      "cta_strength": 0.16,
      "insight_fit": 0.18,
      "message_market_fit": 0.18,
      "consistency": 0.10,
      "story_flow": 0.12,
      "retention_hooks": 0.10,
      "trust": 0.15,
      "next_step": 0.15
    },
    "neuron_index": [
