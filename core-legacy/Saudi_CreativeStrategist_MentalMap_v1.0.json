      "title": "Saudi Strategic Worldview",
      "why_it_exists": "Sets the mental frame: KSA is a state + vision + programs + market, not a market alone.",
      "core_principles": [
        {
          "id": "P0_1",
          "text": "Decisions can be policy-driven as much as market-driven."
        },
        {
          "id": "P0_2",
          "text": "Time horizon matters: today vs 2030."
        },
        {
          "id": "P0_3",
          "text": "Form and narrative can be as important as tactics."
        },
        {
          "id": "P0_4",
          "text": "Sometimes silence is strategic."
        }
      ],
      "outputs_influenced": [
        "strategy_direction",
        "narrative_tone",
        "risk_posture"
