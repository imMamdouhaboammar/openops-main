{
  "name": "@openops/studio",
  "version": "2.0.0",
  "description": "OpenOps Studio - Complete Multi-Agent Operational Architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "boot": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "qa:boot": "tsx scripts/qa-boot-test.ts",
    "generate:module": "tsx scripts/generate-module.ts",
    "validate:config": "tsx scripts/validate-config.ts",
    "docs": "typedoc --out docs src",
    "prepare": "husky install",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "reset": "npm run clean && npm install"
  },
  "keywords": [
    "multi-agent",
    "orchestration",
    "ai",
    "automation",
    "devops",
    "saas",
    "production-team",
    "governance",
    "security",
    "analytics"
  ],
  "author": "OpenOps Foundation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openops/studio.git"
  },
  "bugs": {
    "url": "https://github.com/openops/studio/issues"
  },
  "homepage": "https://openops.ai",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-kms": "^3.955.0",
    "@aws-sdk/client-s3": "^3.955.0",
    "@aws-sdk/client-secrets-manager": "^3.955.0",
    "@pinecone-database/pinecone": "^6.1.3",
    "@sentry/node": "^8.46.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.37.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "neo4j-driver": "^6.0.1",
    "node-cache": "^5.1.2",
    "openai": "^6.15.0",
    "pg": "^8.16.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.0",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "speckit": "^0.1.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.25.8"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/dist/**"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "00_governance",
      "01_orchestration",
      "02_agents",
      "03_product",
      "04_research",
      "05_architecture",
      "06_security",
      "07_tracking",
      "08_ux",
      "09_tooling"
    ],
    "ext": "ts,json",
    "ignore": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "dist/**",
      "node_modules/**"
    ],
    "exec": "ts-node 01_orchestration/runtime/index.ts"
  }
}
