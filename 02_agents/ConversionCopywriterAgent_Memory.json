{
  "memory_and_learning_system": {
    "version": "1.0.0",
    "agent": "ConversionCopywriterAgent",
    "description": "Comprehensive memory architecture and continuous learning system",
    "author": "OpenOps Studio | Mamdouh Aboammar",
    
    "memory_structure": {
      "short_term_memory": {
        "name": "Active Session Context",
        "description": "Information retained during current task/project",
        "retention_period": "Until task completion",
        "storage_type": "in_memory_buffer",
        "contents": {
          "current_project": {
            "client_name": "string",
            "project_id": "uuid",
            "brief_summary": "compressed_context",
            "target_audience": "persona_snapshot",
            "selected_framework": "framework_name",
            "workflow_mode": "sprint|quick|consultation|ab_test",
            "current_phase": "research|messaging|drafting|rewriting|proof|crx|publish",
            "feedback_history": ["iteration_1", "iteration_2"],
            "stakeholder_preferences": {
              "tone": "formal|casual|egyptian_dialect",
              "length": "short|medium|long",
              "emphasis": "emotional|logical|balanced"
            }
          },
          "conversation_context": {
            "questions_asked": ["q1", "q2"],
            "clarifications_provided": ["c1", "c2"],
            "objections_raised": ["o1", "o2"],
            "decisions_made": ["d1", "d2"]
          },
          "research_buffer": {
            "umdp_data": "structured_research_output",
            "pain_points": ["pain_1", "pain_2"],
            "desires": ["desire_1", "desire_2"],
            "objections": ["objection_1", "objection_2"],
            "competitor_insights": ["insight_1", "insight_2"]
          }
        }
      },
      
      "episodic_memory": {
        "name": "Project History Archive",
        "description": "Past projects and their outcomes",
        "retention_period": "Permanent (with periodic pruning)",
        "storage_type": "structured_database",
        "schema": {
          "project_id": "uuid",
          "timestamp": "iso_date",
          "client_info": {
            "name": "string",
            "industry": "string",
            "audience_type": "b2c|b2b|mixed"
          },
          "project_details": {
            "type": "landing_page|ad_campaign|email_sequence|consultation",
            "framework_used": "PAS|BAB|HVC|4Ps|etc",
            "tone_used": "formal|casual|egyptian_dialect",
            "word_count": "number",
            "platform": "facebook|instagram|google|website|email"
          },
          "performance_data": {
            "baseline_conversion_rate": "percentage",
            "final_conversion_rate": "percentage",
            "improvement": "percentage",
            "engagement_metrics": {
              "ctr": "percentage",
              "bounce_rate": "percentage",
              "time_on_page": "seconds"
            },
            "qualitative_feedback": "string"
          },
          "success_patterns": {
            "what_worked": ["pattern_1", "pattern_2"],
            "what_didnt": ["antipattern_1", "antipattern_2"],
            "key_insight": "string"
          },
          "artifacts": {
            "brief": "file_path",
            "research": "file_path",
            "final_copy": "file_path",
            "variations": ["variant_1_path", "variant_2_path"]
          }
        },
        "indexing": {
          "by_industry": "enable_quick_retrieval",
          "by_framework": "enable_quick_retrieval",
          "by_audience": "enable_quick_retrieval",
          "by_performance": "enable_quick_retrieval"
        }
      },
      
      "semantic_memory": {
        "name": "Knowledge Base",
        "description": "General patterns, principles, and learned rules",
        "retention_period": "Permanent (evolving)",
        "storage_type": "knowledge_graph",
        "categories": {
          "industry_insights": {
            "structure": {
              "industry_name": "string",
              "typical_pain_points": ["pain_1", "pain_2"],
              "common_objections": ["objection_1", "objection_2"],
              "effective_hooks": ["hook_1", "hook_2"],
              "proof_types_that_work": ["social|authority|statistics"],
              "language_preferences": "formal|casual|mixed",
              "trust_building_requirements": "high|medium|low",
              "decision_speed": "fast|moderate|slow"
            },
            "examples": {
              "ecommerce_fashion": {
                "pain_points": ["uncertainty_about_quality", "sizing_issues", "delivery_concerns"],
                "objections": ["cant_try_before_buy", "return_hassle", "scam_fear"],
                "effective_hooks": ["social_proof_images", "limited_stock_urgency", "celebrity_endorsement"],
                "proof_types": ["customer_photos", "video_reviews", "return_guarantee"],
                "trust_requirements": "high"
              },
              "saas_b2b": {
                "pain_points": ["roi_uncertainty", "integration_complexity", "vendor_lock_in_fear"],
                "objections": ["price_too_high", "team_wont_adopt", "security_concerns"],
                "effective_hooks": ["specific_metric_improvement", "competitor_comparison", "case_study_story"],
                "proof_types": ["demo_video", "integration_list", "enterprise_logos"],
                "trust_requirements": "very_high"
              },
              "egyptian_b2c_services": {
                "pain_points": ["scam_fear", "quality_uncertainty", "price_sensitivity"],
                "objections": ["too_expensive", "dont_trust_online", "prefer_traditional"],
                "effective_hooks": ["social_proof_egyptian_names", "whatsapp_direct_contact", "known_location"],
                "proof_types": ["video_testimonials_egyptian_dialect", "physical_location", "payment_on_delivery"],
                "trust_requirements": "extremely_high"
              }
            }
          },
          
          "audience_archetypes": {
            "structure": {
              "archetype_name": "string",
              "characteristics": ["trait_1", "trait_2"],
              "decision_drivers": "emotional|logical|mixed",
              "messaging_approach": "string",
              "proof_preferences": ["type_1", "type_2"],
              "objection_patterns": ["objection_1", "objection_2"]
            },
            "library": {
              "anxious_researcher": {
                "characteristics": ["overthinks_decisions", "seeks_extensive_info", "fears_mistakes"],
                "decision_drivers": "logical_with_emotional_undercurrent",
                "messaging_approach": "Detailed, transparent, education-focused",
                "proof_preferences": ["detailed_case_studies", "comparison_charts", "expert_opinions"],
                "objection_patterns": ["need_more_info", "what_if_scenarios", "hidden_costs_fear"]
              },
              "impulsive_buyer": {
                "characteristics": ["quick_decisions", "emotion_driven", "fomo_susceptible"],
                "decision_drivers": "emotional",
                "messaging_approach": "Simple, visual, urgency-based",
                "proof_preferences": ["social_proof", "limited_time_offers", "instant_gratification"],
                "objection_patterns": ["price_if_too_high", "delivery_speed"]
              },
              "skeptical_professional": {
                "characteristics": ["risk_averse", "data_driven", "authority_respecting"],
                "decision_drivers": "logical",
                "messaging_approach": "Professional, evidence-based, ROI-focused",
                "proof_preferences": ["statistics", "whitepapers", "enterprise_logos", "certifications"],
                "objection_patterns": ["prove_roi", "integration_concerns", "vendor_reliability"]
              },
              "egyptian_family_buyer": {
                "characteristics": ["value_conscious", "seeks_social_approval", "tradition_respecting"],
                "decision_drivers": "mixed_emotional_social",
                "messaging_approach": "Warm, family-focused, value-emphasis",
                "proof_preferences": ["neighbor_recommendations", "known_brands", "value_for_money"],
                "objection_patterns": ["too_expensive", "is_it_halal", "what_will_people_say"]
              }
            }
          },
          
          "framework_effectiveness_matrix": {
            "description": "Which framework works best in which context",
            "structure": {
              "framework_name": "string",
              "best_for": ["context_1", "context_2"],
              "weak_for": ["context_1", "context_2"],
              "average_performance": "conversion_lift_percentage",
              "sample_size": "number"
            },
            "data": {
              "PAS": {
                "best_for": ["high_pain_point_awareness", "solution_aware_audience", "egyptian_b2c"],
                "weak_for": ["unaware_audience", "luxury_positioning"],
                "contexts_tested": 47,
                "average_lift": "32%",
                "notes": "Extremely effective in Egyptian market due to cultural acceptance of problem discussion"
              },
              "BAB": {
                "best_for": ["transformation_products", "before_after_visuals", "weight_loss_beauty"],
                "weak_for": ["abstract_services", "b2b_complex_sales"],
                "contexts_tested": 31,
                "average_lift": "28%",
                "notes": "Visual contrast amplifies effectiveness"
              },
              "HVC": {
                "best_for": ["short_form_ads", "social_media", "impulse_purchases"],
                "weak_for": ["complex_products", "high_ticket_items"],
                "contexts_tested": 89,
                "average_lift": "22%",
                "notes": "Speed is strength - works in scroll-heavy environments"
              },
              "4Ps": {
                "best_for": ["landing_pages", "b2b", "considered_purchases"],
                "weak_for": ["time_constrained_readers", "low_engagement_audiences"],
                "contexts_tested": 38,
                "average_lift": "41%",
                "notes": "High lift but requires reader commitment"
              }
            }
          },
          
          "cognitive_bias_application_guide": {
            "description": "When and how to use specific psychological principles",
            "library": {
              "loss_aversion": {
                "principle": "People fear loss more than they value equivalent gain",
                "application_scenarios": ["deadline_urgency", "limited_stock", "price_increase_coming"],
                "copy_patterns": [
                  "Don't miss out on [benefit]",
                  "Last chance to avoid [negative]",
                  "Spots running out - only X left"
                ],
                "effectiveness": "high",
                "caution": "Must be truthful - false scarcity destroys trust"
              },
              "social_proof": {
                "principle": "People follow what others do",
                "application_scenarios": ["new_products", "trust_building", "egyptian_market"],
                "copy_patterns": [
                  "Join 5000+ happy customers",
                  "Ahmed from Cairo says...",
                  "Most popular choice"
                ],
                "effectiveness": "very_high_in_egyptian_context",
                "caution": "Must be specific and credible"
              },
              "anchoring": {
                "principle": "First number seen becomes reference point",
                "application_scenarios": ["pricing_pages", "before_after_comparisons", "value_stacking"],
                "copy_patterns": [
                  "Usually 1000 EGP, today only 499 EGP",
                  "Competitors charge 50% more for less",
                  "Worth 5000 EGP, yours for 999 EGP"
                ],
                "effectiveness": "high",
                "caution": "Anchor must be believable"
              },
              "authority": {
                "principle": "People trust experts and institutions",
                "application_scenarios": ["b2b", "health_products", "technical_services"],
                "copy_patterns": [
                  "Approved by [authority]",
                  "Dr. [Name] recommends",
                  "Used by [prestigious organization]"
                ],
                "effectiveness": "very_high_in_professional_context",
                "caution": "Must be verifiable"
              }
            }
          },
          
          "egyptian_market_intelligence": {
            "description": "Deep cultural and behavioral insights for Egyptian audience",
            "categories": {
              "language_patterns": {
                "trust_words": ["ضمان", "مضمون", "مجرب", "معروف", "أصلي", "مكفول"],
                "urgency_words": ["دلوقتي", "انهاردة", "آخر فرصة", "العرض لحد", "بسرعة"],
                "value_words": ["وفر", "أقل سعر", "مش هتلاقي", "عرض خاص", "ببلاش"],
                "social_words": ["الناس بتقول", "معظم العملاء", "زي ما أحمد قال", "كلهم جربوه"]
              },
              "pain_point_hierarchy": {
                "top_pains": [
                  "scam_fear",
                  "quality_uncertainty",
                  "price_too_high",
                  "delivery_issues",
                  "no_warranty_support"
                ],
                "addressing_order": "Trust first, value second, convenience third"
              },
              "trust_building_essentials": {
                "must_haves": [
                  "visible_phone_number_whatsapp",
                  "physical_location_if_applicable",
                  "egyptian_testimonials_with_names",
                  "payment_flexibility",
                  "clear_return_policy"
                ],
                "trust_multipliers": [
                  "video_testimonials_in_egyptian_dialect",
                  "delivery_proof_screenshots",
                  "famous_person_endorsement",
                  "been_in_business_for_years"
                ]
              },
              "platform_behaviors": {
                "facebook": {
                  "peak_times": ["9pm-12am", "1pm-3pm"],
                  "content_preferences": "video_over_text",
                  "engagement_drivers": "comments_and_shares_matter_most",
                  "ad_fatigue": "high_need_fresh_creative_weekly"
                },
                "instagram": {
                  "peak_times": ["8pm-11pm", "12pm-2pm"],
                  "content_preferences": "aesthetic_visual_first",
                  "engagement_drivers": "stories_and_reels_outperform_feed",
                  "ad_fatigue": "moderate"
                },
                "whatsapp": {
                  "role": "closing_and_support_primary_channel",
                  "preferences": "voice_notes_common",
                  "response_expectations": "fast_reply_expected",
                  "trust_level": "highest_familiarity"
                }
              },
              "pricing_psychology": {
                "number_patterns": ["999_not_1000", "end_with_9_or_5"],
                "comparison_important": "always_show_savings_amount_and_percentage",
                "payment_options": "installment_mention_increases_conversion_40_percent",
                "free_shipping_threshold": "powerful_motivator"
              }
            }
          }
        }
      },
      
      "procedural_memory": {
        "name": "Skill Execution Patterns",
        "description": "How to perform specific tasks - the 'muscle memory' of copywriting",
        "contents": {
          "writing_procedures": {
            "rewriting_for_clarity": {
              "steps": [
                "Read sentence aloud",
                "Identify unclear words/phrases",
                "Replace with simpler alternatives",
                "Ensure meaning preserved",
                "Re-read for flow"
              ],
              "triggers": ["clarity_test_fail", "readability_score_low"]
            },
            "adding_emotional_resonance": {
              "steps": [
                "Identify primary emotion (fear, desire, frustration, hope)",
                "Find specific manifestation of that emotion",
                "Use sensory language",
                "Connect to personal identity",
                "Avoid generic emotion words"
              ],
              "triggers": ["copy_feels_flat", "low_engagement_predicted"]
            },
            "objection_preemption": {
              "steps": [
                "List top 3 objections from research",
                "Find natural place to address each",
                "State objection directly or indirectly",
                "Provide evidence-based response",
                "Reframe as benefit when possible"
              ],
              "triggers": ["conversion_funnel_dropoff", "consultation_mode"]
            }
          },
          "optimization_procedures": {
            "ab_test_analysis": {
              "steps": [
                "Check statistical significance (95% confidence, 100+ conversions/variant)",
                "Identify winning variant",
                "Analyze why it won (hypothesis validation)",
                "Extract pattern for future use",
                "Document in semantic memory"
              ]
            },
            "conversion_rate_diagnosis": {
              "steps": [
                "Run through 5-filter test (clarity, relevance, trust, safety, effort)",
                "Identify which filter is failing",
                "Review heatmaps/analytics if available",
                "Prioritize fixes by impact",
                "Implement highest-impact change first"
              ]
            }
          }
        }
      }
    },
    
    "learning_system": {
      "continuous_improvement": {
        "feedback_loops": {
          "project_outcome_learning": {
            "trigger": "Project completion + performance data available",
            "process": [
              "Compare predicted vs actual performance",
              "Identify surprises (better or worse than expected)",
              "Analyze what caused variance",
              "Update framework_effectiveness_matrix",
              "Update industry_insights if pattern emerges",
              "Store in episodic_memory"
            ],
            "frequency": "After every project with measurable results"
          },
          
          "pattern_recognition": {
            "trigger": "Every 10 projects or monthly",
            "process": [
              "Query episodic_memory for recent projects",
              "Group by industry, framework, audience",
              "Identify recurring success patterns",
              "Identify recurring failure patterns",
              "Update semantic_memory knowledge_graph",
              "Generate insights report"
            ],
            "frequency": "Monthly or per 10 projects"
          },
          
          "market_intelligence_updates": {
            "trigger": "Quarterly or when market shift detected",
            "process": [
              "Review egyptian_market_intelligence data",
              "Compare with recent project performance",
              "Identify changing patterns (e.g., new platform behaviors, shifting trust requirements)",
              "Update market intelligence sections",
              "Alert StaffEngineer if major shift detected"
            ],
            "frequency": "Quarterly"
          }
        },
        
        "knowledge_acquisition": {
          "research_integration": {
            "sources": [
              "Industry case studies",
              "Behavioral psychology research",
              "Competitor analysis",
              "Client feedback",
              "A/B test results"
            ],
            "process": [
              "Validate source credibility",
              "Extract actionable insights",
              "Map to existing knowledge_graph",
              "Identify conflicts with current beliefs",
              "Update or create new semantic_memory entries",
              "Test new knowledge in next applicable project"
            ]
          },
          
          "collaborative_learning": {
            "description": "Learn from other agents in OpenOps ecosystem",
            "interactions": {
              "ResearchBriefAgent": {
                "learning_opportunity": "Audience insight patterns",
                "sharing_back": "Which insights led to best copy performance"
              },
              "MarketingStrategist": {
                "learning_opportunity": "Campaign strategy context",
                "sharing_back": "Message hierarchy effectiveness"
              },
              "DataAnalyst": {
                "learning_opportunity": "Performance metrics interpretation",
                "sharing_back": "Copy elements correlated with conversion"
              }
            }
          }
        },
        
        "skill_development": {
          "capability_expansion": {
            "new_framework_mastery": {
              "process": [
                "Study framework theory",
                "Analyze 5 successful examples",
                "Apply to low-risk project",
                "Compare performance to established frameworks",
                "If effective, add to framework_templates",
                "Document in semantic_memory"
              ]
            },
            "new_industry_expertise": {
              "process": [
                "Research industry deeply (pain points, objections, language)",
                "Observe 3 successful campaigns in industry",
                "Create initial industry_insights entry",
                "Apply learnings to first project",
                "Refine based on outcomes",
                "Build industry-specific templates"
              ]
            }
          },
          
          "performance_calibration": {
            "description": "Ensure predictions and assessments stay accurate",
            "metrics_tracked": {
              "conversion_prediction_accuracy": {
                "measure": "Predicted lift vs actual lift",
                "target": "Within 15% margin",
                "adjustment": "If consistently off, recalibrate models"
              },
              "framework_selection_accuracy": {
                "measure": "Did selected framework outperform alternatives in A/B tests",
                "target": "70%+ accuracy",
                "adjustment": "Update framework_effectiveness_matrix weights"
              },
              "clarity_test_correlation": {
                "measure": "Pre-publish clarity score vs actual comprehension metrics",
                "target": "80%+ correlation",
                "adjustment": "Refine clarity assessment criteria"
              }
            }
          }
        }
      },
      
      "memory_management": {
        "consolidation": {
          "description": "Move information from short-term to long-term memory appropriately",
          "trigger": "Project completion",
          "process": [
            "Extract key insights from short_term_memory",
            "Store full project in episodic_memory",
            "Update semantic_memory if patterns found",
            "Update procedural_memory if new skill developed",
            "Clear short_term_memory for next project"
          ]
        },
        
        "pruning": {
          "description": "Remove outdated or low-value memories to maintain performance",
          "frequency": "Quarterly",
          "criteria": {
            "episodic_memory": "Keep all high-performance projects, prune projects >2 years old with mediocre results",
            "semantic_memory": "Update entries that conflict with recent strong evidence",
            "procedural_memory": "Remove procedures not used in 6 months unless high-value"
          }
        },
        
        "retrieval_optimization": {
          "description": "Ensure relevant memories are quickly accessible",
          "indexing_strategy": {
            "primary_keys": ["industry", "audience_type", "framework", "performance_tier"],
            "secondary_keys": ["platform", "tone", "word_count", "client_type"],
            "full_text_search": "enabled_on_insights_and_feedback"
          },
          "caching": {
            "hot_memories": "Last 5 projects, current industry insights, top frameworks",
            "warm_memories": "Last 20 projects, all industry insights",
            "cold_memories": "Archive older than 1 year"
          }
        }
      }
    },
    
    "integration_with_workflows": {
      "research_phase": {
        "memory_usage": [
          "Retrieve industry_insights for target industry",
          "Retrieve audience_archetypes matching persona",
          "Retrieve past projects for similar audience",
          "Load egyptian_market_intelligence if applicable"
        ]
      },
      
      "messaging_phase": {
        "memory_usage": [
          "Retrieve framework_effectiveness_matrix to select framework",
          "Retrieve cognitive_bias_application_guide",
          "Retrieve successful_headlines from similar projects",
          "Load procedural_memory for message_hierarchy_building"
        ]
      },
      
      "drafting_phase": {
        "memory_usage": [
          "Retrieve framework_templates",
          "Retrieve tone_guide",
          "Load procedural_memory for writing_procedures",
          "Reference similar successful copy from episodic_memory"
        ]
      },
      
      "optimization_phase": {
        "memory_usage": [
          "Retrieve ab_test_planner templates",
          "Load past A/B test results for similar contexts",
          "Retrieve conversion_audit_checklist",
          "Load procedural_memory for optimization_procedures"
        ]
      },
      
      "post_project": {
        "memory_update": [
          "Store project in episodic_memory",
          "Update framework_effectiveness_matrix if results significant",
          "Update industry_insights if new patterns emerged",
          "Update egyptian_market_intelligence if market behavior noted",
          "Run pattern_recognition if threshold reached"
        ]
      }
    },
    
    "api_endpoints": {
      "description": "Programmatic access to memory system",
      "endpoints": {
        "retrieve_similar_projects": {
          "input": {
            "industry": "string",
            "audience_type": "string",
            "limit": "number"
          },
          "output": "array_of_project_objects_from_episodic_memory"
        },
        
        "get_industry_insights": {
          "input": {
            "industry": "string"
          },
          "output": "industry_insights_object"
        },
        
        "get_framework_recommendation": {
          "input": {
            "context": "object_with_industry_audience_platform",
            "top_n": "number"
          },
          "output": "ranked_list_of_frameworks_with_rationale"
        },
        
        "store_project_outcome": {
          "input": {
            "project_object": "full_project_details_with_performance"
          },
          "output": "confirmation_and_insights_extracted"
        },
        
        "query_cognitive_bias": {
          "input": {
            "bias_name": "string"
          },
          "output": "application_guide_object"
        }
      }
    }
  }
}
