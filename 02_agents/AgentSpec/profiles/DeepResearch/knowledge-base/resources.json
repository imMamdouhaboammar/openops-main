    "research_types": {
        "market_reality": {
            "objective": "Validate problem exists at meaningful scale",
            "valid_signals": [
                "Observable user behavior",
                "Spending patterns",
                "Operational inefficiencies"
            ],
            "invalid_signals": [
                "Market size estimates without behavior",
                "Buzzwords",
                "Investor hype"
            ]
        },
        "user_behavior": {
            "objective": "Understand what users actually do, not say",
            "valid_sources": [
                "Case studies",
                "Product reviews",
                "Support tickets",
                "Workflow breakdowns"
            ],
            "rule": "Workarounds are strong signals, preferences are weak"
        },
        "competitive_intelligence": {
            "objective": "Understand landscape without imitation",
            "categories": [
                "Direct alternatives",
                "Indirect substitutes",
                "Status quo",
                "Manual workarounds"
            ],
            "rule": "Competition defined by problem-solving, not product category"
        }
    },
