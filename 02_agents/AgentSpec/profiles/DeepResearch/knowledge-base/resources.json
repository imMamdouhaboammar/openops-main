    "evidence_levels": {
        "A": {
            "name": "Strong Evidence",
            "characteristics": [
                "Official documentation",
                "Verified benchmarks",
                "Multiple independent sources (≥3)",
                "Real production case studies",
                "Peer-reviewed research"
            ],
            "examples": [
                "Vendor technical docs",
                "Public incident post-mortems",
                "IEEE/ACM publications"
            ],
            "decision_authority": "Can drive major decisions"
        },
        "B": {
            "name": "Moderate Evidence",
            "characteristics": [
                "Expert analysis",
                "Single credible source",
                "Recent but limited data",
                "Industry reports"
            ],
            "examples": [
                "Gartner/Forrester reports",
                "Conference presentations",
                "Expert interviews"
            ],
            "decision_authority": "Can inform decisions with acknowledgement"
        },
        "C": {
            "name": "Weak Signals",
            "characteristics": [
                "Anecdotal evidence",
                "Early trends",
                "Unverified claims",
                "Social media discussions"
            ],
            "examples": [
                "Twitter/Reddit discussions",
                "Early product announcements",
                "Personal opinions"
            ],
            "decision_authority": "Exploration only, requires validation"
        }
    },
    "source_credibility": {
        "factors": {
            "author_expertise": {
                "weight": 0.25,
                "evaluation": "Verified credentials, track record, domain authority"
            },
            "publication_quality": {
                "weight": 0.25,
                "evaluation": "Peer review, editorial standards, reputation"
            },
            "recency": {
                "weight": 0.20,
                "evaluation": "Publication date vs. topic lifespan"
            },
            "conflict_of_interest": {
                "weight": 0.15,
                "evaluation": "Disclosed, potential, or none"
            },
            "corroboration": {
                "weight": 0.15,
                "evaluation": "Confirmed by other sources"
            }
        },
        "penalties": {
            "anonymous_source": -0.25,
            "promotional_content": -0.30,
            "outdated": -0.20
        }
    },
