{
    "vcot_pipeline": {
        "name": "Visual Chain-of-Thought Pipeline",
        "type": "mandatory",
        "description": "Core 6-stage pipeline for all image generation tasks",
        "stages": [
            {
                "stage": 1,
                "name": "UNDERSTAND",
                "tool": "intent-clarifier",
                "actions": [
                    "Parse user request",
                    "Extract subject, style, context, technical specs",
                    "Identify ambiguities",
                    "Calculate confidence score"
                ],
                "validation": {
                    "confidence_threshold": 0.9,
                    "on_fail": "Request clarification from user"
                }
            },
            {
                "stage": 2,
                "name": "PLAN",
                "tool": "visual-planner",
                "actions": [
                    "Create composition blueprint",
                    "Define lighting profile",
                    "Specify color palette and harmony",
                    "Set technical specifications"
                ],
                "validation": {
                    "completeness_threshold": 0.95,
                    "on_fail": "Fill missing elements with defaults"
                }
            },
            {
                "stage": 3,
                "name": "CRAFT",
                "tool": "prompt-engineer",
                "actions": [
                    "Transform blueprint to narrative prompt",
                    "Apply Gemini 3 Pro Image best practices",
                    "Include technical layer",
                    "Validate prompt structure"
                ],
                "best_practices": [
                    "Narrative over keywords",
                    "6-part structure",
                    "Technical specs included",
                    "Style references explicit"
                ]
            },
            {
                "stage": 4,
                "name": "GENERATE",
                "tool": "generation-engine",
                "actions": [
                    "Execute with Gemini 3 Pro Image",
                    "Apply reference images if provided",
                    "Generate at specified resolution",
                    "Capture metadata"
                ],
                "model": "gemini-3-pro-image-preview",
                "fallback": "gemini-2.5-flash-image"
            },
            {
                "stage": 5,
                "name": "EVALUATE",
                "tool": "quality-assessor",
                "actions": [
                    "Score against 6 criteria",
                    "Calculate weighted quality score",
                    "Identify specific issues",
                    "Determine verdict"
                ],
                "criteria": [
                    "subject_accuracy (25%)",
                    "composition_match (20%)",
                    "style_fidelity (20%)",
                    "technical_quality (15%)",
                    "text_accuracy (10%)",
                    "mood_atmosphere (10%)"
                ],
                "routing": {
                    "pass": "Output (score >= 0.85)",
                    "conditional": "Minor refinement (score >= 0.70)",
                    "fail": "Stage 6 (score < 0.70)"
                }
            },
            {
                "stage": 6,
                "name": "REFINE",
                "tool": "iterative-refiner",
                "condition": "Only if Stage 5 returns FAIL or CONDITIONAL",
                "actions": [
                    "Analyze failure points",
                    "Select refinement strategy",
                    "Generate improved prompt",
                    "Decide: regenerate or edit",
                    "Loop back to Stage 4"
                ],
                "max_iterations": 3,
                "strategies": {
                    "subject_wrong": "regenerate_with_clearer_subject",
                    "composition_off": "add_explicit_composition_guidance",
                    "style_mismatch": "add_style_reference_images",
                    "technical_issues": "adjust_resolution_and_quality",
                    "text_errors": "regenerate_with_quoted_text",
                    "mood_wrong": "adjust_lighting_and_color"
                }
            }
        ]
    },
