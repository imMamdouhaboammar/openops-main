    },
    "workflows": {
        "state_machine_protocol": {
            "enabled": true,
            "description": "7-stage systematic content creation workflow",
            "workflow_file": "workflows/state-machine.md",
            "stages": [
                "safety_scope",
                "content_discovery",
                "cql_lock",
                "research_grounding",
                "content_strategy",
                "content_creation",
                "quality_assurance",
                "delivery_documentation"
            ],
            "skip_allowed": false,
            "default_mode": true
        },
        "diagnosis_first_mode": {
            "enabled": true,
            "description": "Full state machine workflow for new clients",
            "use_when": "new_client_or_complex_request",
            "stages": [
                "safety_scope",
                "content_discovery",
                "cql_lock",
                "research_grounding",
                "content_strategy",
                "content_creation",
                "quality_assurance",
                "delivery_documentation"
            ]
        },
        "quick_mode": {
            "enabled": true,
            "description": "Streamlined workflow when complete brief provided",
            "use_when": "user_provides_complete_brief",
            "total_duration_hours": 3,
            "stages": [
                "brief_review",
                "rapid_research",
                "content_creation",
                "quality_check"
            ],
            "steps": [
                {
                    "name": "brief_review",
                    "duration_minutes": 15
                },
                {
                    "name": "rapid_research",
                    "duration_minutes": 30
                },
                {
                    "name": "first_draft",
                    "duration_minutes": 60
                },
                {
                    "name": "refinement",
                    "duration_minutes": 45
                },
                {
                    "name": "delivery",
                    "duration_minutes": 30
                }
            ]
        },
        "consultation_mode": {
            "enabled": true,
            "description": "Content review and improvement workflow",
            "use_when": "reviewing_existing_content",
            "stages": [
                "content_audit",
                "gap_analysis",
                "recommendations",
                "rewrite_if_requested"
            ],
            "steps": [
                "content_audit",
                "gap_analysis",
                "improvement_recommendations",
                "rewrite_suggestions",
                "implementation_guidance"
            ]
        },
        "content_discovery_interview": {
            "enabled": true,
            "workflow_file": "workflows/content-discovery-interview.md",
            "max_questions_per_round": 5,
            "max_rounds": 3,
            "required_elements": [
                "brand_identity",
                "content_goal",
                "target_audience",
                "platform",
                "brand_voice",
                "constraints"
            ]
        },
        "content_question_lock": {
            "enabled": true,
            "workflow_file": "workflows/content-question-lock.md",
            "required_elements": [
                "content_type",
                "specific_audience",
                "specific_action",
                "platform",
                "brand_voice"
            ],
            "validation_required": true,
            "user_confirmation_required": true
        }
    },
    "quality_gates": {
        "enabled": true,
        "config_file": "config/quality_gates.yaml",
        "description": "Systematic quality control gates for content creation",
        "gates": [
            {
                "name": "clarity_gate",
                "target_score": 0.95,
                "priority": "critical",
                "failure_action": "revise_for_clarity"
            },
            {
                "name": "brand_alignment_gate",
                "target_score": 0.90,
                "priority": "critical",
                "failure_action": "realign_with_brand"
            },
            {
                "name": "audience_relevance_gate",
                "target_score": 0.90,
                "priority": "critical",
                "failure_action": "retarget_audience"
            },
            {
                "name": "platform_optimization_gate",
                "target_score": 1.0,
                "priority": "high",
                "failure_action": "optimize_for_platform"
            },
            {
                "name": "cultural_appropriateness_gate",
                "target_score": 1.0,
                "priority": "critical",
                "failure_action": "cultural_review"
            },
            {
                "name": "evidence_gate",
                "target_score": 1.0,
                "priority": "high",
                "failure_action": "add_evidence"
            }
        ],
        "execution_order": [
            "clarity_gate",
            "brand_alignment_gate",
            "audience_relevance_gate",
            "platform_optimization_gate",
            "cultural_appropriateness_gate",
            "evidence_gate"
        ],
        "overall_quality_threshold": 0.85
    },
    "evidence_based_content": {
        "enabled": true,
        "config_file": "config/content_evidence_sources.yaml",
        "description": "Evidence-grounded content creation with source validation",
        "source_tiers": {
            "tier_a": {
                "trust_score": [
                    0.95,
                    0.98
                ],
                "examples": [
                    "platform_official_docs",
                    "academic_research"
                ]
            },
            "tier_b": {
                "trust_score": [
                    0.80,
                    0.90
                ],
                "examples": [
                    "marketing_research",
                    "case_studies"
                ]
            },
            "tier_c": {
                "trust_score": [
                    0.75,
                    0.85
                ],
                "examples": [
                    "practitioner_insights",
                    "industry_reports"
                ]
            },
            "tier_d": {
                "trust_score": [
                    0.30,
                    0.40
                ],
                "examples": [
                    "social_discussions"
                ],
                "note": "context_only_not_confirmations"
            }
        },
        "evidence_requirements": {
            "critical_claims": {
                "confirmations_required": 3,
                "minimum_tier": "tier_b"
            },
            "best_practices": {
                "confirmations_required": 2,
                "minimum_tier": "tier_c"
            },
            "creative_approaches": {
                "confirmations_required": 1,
                "minimum_tier": "tier_c"
            }
        },
        "recency_rules": {
            "platform_specific": 90,
            "general_psychology": 730,
            "cultural_trends": 180
        }
    },
    "performance_metrics": {
        "content_quality": {
            "clarity_score": {
                "target": 95,
                "unit": "percentage"
            },
            "brand_alignment": {
                "target": 90,
                "unit": "percentage"
            },
            "audience_relevance": {
                "target": 90,
                "unit": "percentage"
            }
        },
        "business_impact": {
            "engagement_rate": {
                "target_increase": "5-10",
                "unit": "percentage"
            },
            "reach": {
                "target_increase": "20-30",
                "unit": "percentage"
            },
            "conversion_rate": {
                "target_increase": "15-25",
                "unit": "percentage"
            }
        },
        "process_efficiency": {
            "standard_turnaround": {
                "value": "5-7",
                "unit": "days"
            },
            "quick_mode": {
                "value": "2-4",
                "unit": "hours"
            },
            "revision_cycles": {
                "max": 3
            }
        }
    },
