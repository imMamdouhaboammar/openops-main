    "agent_catalog": {
      "ContentOptimizer": {
        "tier": "L2",
        "domain": "content_creation",
        "description": "Specializes in optimizing content for readability, engagement, SEO, and conversion.",
        "capabilities": [
          "content_analysis_and_scoring",
          "readability_optimization",
          "seo_keyword_optimization",
          "tone_and_style_adjustment",
          "a_b_testing_content_variants",
          "multilingual_optimization"
        ],
        "input_formats": ["text", "markdown", "html", "json"],
        "output_formats": ["optimized_content", "optimization_report", "improvement_suggestions"],
        "performance_metrics": {
          "readability_improvement": "target_20_percent_increase",
          "seo_score_improvement": "target_30_percent_increase",
          "engagement_prediction_accuracy": "target_85_percent"
        },
        "integration_points": [
          "ResearchBriefAgent_for_context",
          "QAOrchestrator_for_quality_validation",
          "MarketingStrategist_for_alignment"
        ],
        "learning_sources": [
          "successful_content_patterns",
          "engagement_metrics",
          "user_feedback",
          "competitive_analysis"
        ]
      },

      "DataAnalyst": {
        "tier": "L2",
        "domain": "analytics",
        "description": "Performs statistical analysis, data mining, pattern recognition, and predictive modeling.",
        "capabilities": [
          "exploratory_data_analysis",
          "statistical_testing",
          "predictive_modeling",
          "anomaly_detection",
          "trend_analysis",
          "visualization_generation",
          "automated_insight_extraction"
        ],
        "tools": [
          "pandas",
          "numpy",
          "scikit_learn",
          "statsmodels",
          "matplotlib",
          "seaborn"
        ],
        "input_formats": ["csv", "json", "parquet", "sql_query_results"],
        "output_formats": ["analysis_reports", "visualizations", "statistical_summaries", "predictions"],
        "performance_metrics": {
          "analysis_accuracy": "target_95_percent",
          "insight_relevance": "target_90_percent",
          "processing_speed": "target_under_5_minutes_for_10MB_data"
        },
        "specializations": {
          "time_series_analysis": "forecasting_trend_decomposition",
          "cohort_analysis": "user_behavior_tracking",
          "attribution_modeling": "marketing_channel_effectiveness"
        }
      },

      "SecurityAuditor": {
        "tier": "L2",
        "domain": "security",
        "description": "Continuously audits system for security vulnerabilities, compliance violations, and threat patterns.",
        "capabilities": [
          "vulnerability_scanning",
          "penetration_testing_simulation",
          "compliance_checking",
          "threat_modeling",
          "security_policy_enforcement",
          "incident_detection",
          "risk_assessment"
        ],
        "frameworks": [
          "OWASP_Top_10",
          "CIS_Benchmarks",
          "NIST_Cybersecurity_Framework",
          "ISO_27001",
          "GDPR",
          "SOC2"
        ],
        "scan_frequency": {
          "continuous_monitoring": "real_time",
          "full_audit": "weekly",
          "compliance_check": "monthly",
          "penetration_test": "quarterly"
        },
        "alert_severity": {
          "critical": "immediate_escalation_and_auto_remediation_if_possible",
          "high": "escalate_within_1_hour",
          "medium": "daily_report",
          "low": "weekly_summary"
        },
        "integration_points": [
          "SecurityLead_for_escalations",
          "ComplianceMonitor_for_regulatory_issues",
          "Orchestrator_for_emergency_responses"
        ]
      },

      "APIIntegrator": {
        "tier": "L3",
