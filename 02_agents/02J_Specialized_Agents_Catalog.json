        {
          "agents": ["DataAnalyst", "CostOptimizer"],
          "synergy": "data_driven_cost_optimization"
        },
        {
          "agents": ["SecurityAuditor", "ComplianceMonitor"],
          "synergy": "comprehensive_security_and_compliance"
        },
