{
  "specialized_agents": {
    "version": "2.0.0",
    "type": "advanced_agent_definitions",
    "description": "Comprehensive definitions for specialized agents with unique capabilities, workflows, and operational patterns within OpenOps.",
    "author": "OpenOps Studio | Created by Mamdouh Aboammar",
    "last_updated": "2025-12-19",
    "governance": {
      "managed_by": "SupervisorAgent",
      "approved_by": "StaffEngineer",
      "compliance_with": [
        "02A_Agent_Roles_Config.json",
        "02E_Agent_Authorization_Matrix.json"
      ]
