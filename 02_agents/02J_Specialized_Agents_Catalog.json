      "common_workflows": [
        {
          "workflow": "content_creation_pipeline",
          "agents": ["ResearchBriefAgent", "ContentOptimizer", "QAOrchestrator"],
          "flow": "research → optimization → quality_assurance"
        },
        {
          "workflow": "security_compliance_audit",
          "agents": ["SecurityAuditor", "ComplianceMonitor", "IncidentResponder"],
          "flow": "audit → compliance_check → incident_handling_if_needed"
        },
        {
          "workflow": "system_optimization",
          "agents": ["DataAnalyst", "CostOptimizer", "WorkflowDesigner"],
          "flow": "analysis → cost_optimization → workflow_improvement"
        }
