          "time_saved": "target_hours_per_week",
          "error_reduction": "target_percentage_decrease",
          "roi": "target_positive_within_3_months"
        }
      },

      "IncidentResponder": {
        "tier": "L2",
        "domain": "incident_management",
        "description": "Detects, triages, and coordinates response to system incidents and emergencies.",
        "capabilities": [
          "incident_detection_and_classification",
          "severity_assessment",
          "automated_initial_response",
          "incident_escalation",
          "coordination_of_response_teams",
          "root_cause_analysis",
          "post_mortem_facilitation",
          "runbook_execution"
        ],
        "incident_severity_levels": {
          "SEV1_CRITICAL": {
            "definition": "complete_service_outage_or_data_breach",
            "response_time": "immediate",
            "escalation": "automatic_to_L0",
            "communication": "stakeholder_notification_required"
          },
          "SEV2_HIGH": {
            "definition": "significant_degradation_affecting_users",
            "response_time": "15_minutes",
            "escalation": "to_L1",
            "communication": "internal_teams"
          },
          "SEV3_MEDIUM": {
            "definition": "minor_issues_with_workarounds",
            "response_time": "1_hour",
            "escalation": "if_unresolved_in_4_hours",
            "communication": "team_level"
          },
          "SEV4_LOW": {
            "definition": "cosmetic_or_non_urgent_issues",
            "response_time": "next_business_day",
            "escalation": "none",
            "communication": "ticket_tracking"
          }
        },
        "automation": [
          "health_check_execution",
          "log_collection",
          "rollback_procedures",
          "failover_activation",
          "notification_distribution"
        ]
      },

