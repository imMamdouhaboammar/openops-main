{
  "name": "@openops/test-kit",
  "version": "0.1.0-alpha",
  "description": "AI-assisted testing framework companion to Spec-Kit. Generate, validate, and heal tests intelligently.",
  "main": "dist/index.js",
  "bin": {
    "test-kit": "dist/bin/test-kit.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch bin/test-kit.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/bin/test-kit.js"
  },
  "keywords": [
    "testing",
    "ai",
    "vibe-coding",
    "test-generation",
    "spec-driven"
  ],
  "author": "OpenOps Studio",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "figlet": "^1.6.0",
    "fs-extra": "^11.2.0",
    "kleur": "^4.1.5",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
