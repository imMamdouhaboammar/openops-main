{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test-Kit Task Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "unit",
        "integration",
        "e2e",
        "ai-eval"
      ]
    },
    "status": {
      "enum": [
        "pending",
        "in-progress",
        "completed",
        "failed"
      ]
    },
    "description": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "type",
    "status"
  ]
}