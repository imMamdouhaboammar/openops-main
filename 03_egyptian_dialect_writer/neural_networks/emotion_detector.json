{
  "network_id": "EDW_EMOTION_DETECTOR_004",
  "network_name": "Emotion Detector & Modulator",
  "network_name_ar": "كاشف وموازن المشاعر",
  "version": "1.0.0",
  "status": "active",
  
  "core_function": "كشف المشاعر وضبط النبرة العاطفية للمحتوى",

  "emotion_detection": {
    "primary_emotions": [
      "enthusiasm",
      "concern",
      "skepticism",
      "confidence",
      "curiosity",
      "urgency"
    ],

    "intensity_levels": {
      "scale": "0_to_1",
      "granularity": "fine_grained",
      "mixed_emotions": "supported"
    },

    "detection_methods": {
      "lexical_analysis": "emotion_bearing_words",
      "syntactic_patterns": "sentence_structure_indicators",
      "punctuation_signals": "exclamation_question_marks",
      "context_inference": "situational_emotion"
    }
  },

  "emotion_modulation": {
    "target_setting": {
      "enthusiasm": {"default": 0.7, "range": "0.3-0.9"},
      "professionalism": {"default": 0.6, "range": "0.4-0.8"},
      "warmth": {"default": 0.8, "range": "0.5-0.95"}
    },

    "adjustment_techniques": [
      "word_choice_modification",
      "punctuation_tuning",
      "expression_intensification",
      "tone_softening"
    ],

    "emotional_authenticity": {
      "avoid_fake_enthusiasm": true,
      "genuine_expression": "priority",
      "context_appropriate": "always"
    }
  },

  "sentiment_analysis": {
    "polarity": ["positive", "neutral", "negative", "mixed"],
    "subjectivity": "opinion_vs_fact_detection",
    "persuasion_level": "conviction_strength"
  },

  "cultural_emotional_mapping": {
    "egyptian_expressions": {
      "excitement": ["جامد!", "رهيب!", "تحفة!"],
      "concern": ["خلي بالك", "انتبه", "حذار"],
      "agreement": ["بالظبط", "صح", "مظبوط"],
      "emphasis": ["فعلاً", "حقيقي", "والله"]
    }
  }
}
