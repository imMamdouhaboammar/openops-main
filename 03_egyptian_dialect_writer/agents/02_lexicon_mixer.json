        "meaning": "directly_to_the_point",
        "usage": "conclusion_or_summary"
      },
      {
        "idiom": "خد عندك بقى",
        "meaning": "pay_attention_to_this",
        "usage": "introducing_important_points"
      },
      {
        "idiom": "الموضوع مش سهل",
        "meaning": "it_is_complicated",
        "usage": "acknowledging_complexity"
      }
    ]
  },

  "mixing_algorithm": {
    "step_1_context_analysis": {
      "identify_domain": true,
      "determine_technicality": true,
      "assess_audience_level": true
    },

    "step_2_term_selection": {
      "technical_terms": "always_english",
      "common_concepts": "egyptian_colloquial",
      "hybrid_terms": "arabized_form"
    },

    "step_3_balance_check": {
      "ensure_naturalness": true,
      "avoid_overuse_of_english": true,
      "maintain_egyptian_flavor": true,
      "target_ratios": {
        "technical_content": {
          "english": 0.40,
          "egyptian": 0.40,
          "arabized": 0.20
        },
        "general_content": {
          "english": 0.25,
          "egyptian": 0.60,
          "arabized": 0.15
        }
      }
    },

    "step_4_integration": {
      "smooth_transitions": true,
      "grammatical_consistency": true,
      "cultural_appropriateness": true
    }
  },

  "quality_metrics": {
    "naturalness_score": {
      "target": 0.90,
      "measurement": "fluency_and_readability"
    },
    "lexical_diversity": {
      "target": 0.75,
      "measurement": "unique_terms_variety"
    },
    "cultural_authenticity": {
      "target": 0.85,
      "measurement": "egyptian_expressions_usage"
    },
    "technical_accuracy": {
      "target": 0.95,
      "measurement": "correct_term_usage"
    }
  },

  "integration_points": {
    "receives_input_from": [
      "tone_master",
      "context_analyzer",
      "tech_terminology_database"
    ],
    "sends_output_to": [
      "structure_architect",
      "quality_checker",
      "human_mimicker"
    ]
  },

  "learning_capability": {
    "new_terms_detection": true,
    "trending_terms_tracking": true,
    "usage_pattern_learning": true,
    "feedback_incorporation": true
  }
}
