{
    "standard_workflows": [
        {
            "id": "grounded-strategy",
            "name": "Grounded Strategy Workflow",
            "trigger": "Any strategy or tactical request",
            "mandatory": true,
            "steps": [
                {
                    "step": 1,
                    "name": "Clarify Mission",
                    "actions": [
                        "Define goal and assumptions",
                        "Identify funnel stage",
                        "Map constraints",
                        "Define success criteria"
                    ],
                    "duration": "5 min"
                },
                {
                    "step": 2,
                    "name": "External Grounding",
                    "tool": "grounding-engine",
                    "sources": [
                        "Google",
                        "Reforge",
                        "DigitalMarketer",
                        "Platform docs"
                    ],
                    "search_for": "Latest best practices, frameworks, case studies"
                },
                {
                    "step": 3,
                    "name": "Internal Grounding",
                    "analyze": [
                        "Positioning & messaging",
                        "Audience & ICP",
                        "Current funnels",
                        "Performance data",
                        "Past experiments"
                    ]
                },
                {
                    "step": 4,
                    "name": "Short Internal Plan",
                    "tool": "internal-plan-generator",
                    "output": [
                        "Diagnosis",
                        "Direction",
                        "Levers",
                        "Experiments",
                        "Measurement"
                    ]
                },
                {
                    "step": 5,
                    "name": "Detailed Diagnosis",
                    "identify": [
                        "Weak positioning",
                        "Funnel leaks",
                        "Bad offers",
                        "Misaligned metrics",
                        "Channel overdependence"
                    ]
                },
                {
                    "step": 6,
                    "name": "Full Strategy",
                    "define": [
                        "Target segments",
                        "Value proposition",
                        "Main messages",
                        "Channel roles",
                        "Growth levers"
                    ]
                },
                {
                    "step": 7,
                    "name": "Execution Tactics",
                    "deliverables": [
                        "Campaign structures",
                        "Content frameworks",
                        "Ad examples",
                        "Email flows",
                        "Landing pages"
                    ]
                },
                {
                    "step": 8,
                    "name": "Experiments & Loops",
                    "document": [
                        "Hypothesis (if/then/because)",
                        "Variation description",
                        "Success metrics",
                        "Growth loop potential"
                    ]
                },
                {
                    "step": 9,
                    "name": "Measurement",
                    "specify": [
                        "Primary KPIs",
                        "Secondary KPIs",
                        "Review cadence",
                        "Scale/Kill criteria"
                    ]
                }
            ]
        },
        {
            "id": "quick-response",
            "name": "Quick Response Workflow",
            "trigger": "Simple tactical question",
            "steps": [
                {
                    "step": 1,
                    "name": "Quick Ground",
                    "action": "Rapid external check if needed"
                },
                {
                    "step": 2,
                    "name": "Context Check",
                    "action": "Does this fit existing strategy?"
                },
                {
                    "step": 3,
                    "name": "Direct Answer",
                    "format": "Actionable recommendation with rationale"
                }
            ],
            "note": "For simple questions, skip full workflow but maintain grounding mindset"
        },
        {
            "id": "funnel-audit",
            "name": "Funnel Audit Workflow",
            "trigger": "Request for funnel analysis",
            "steps": [
                {
                    "step": 1,
                    "name": "Data Collection",
                    "collect": [
                        "Metrics by stage (AARRR)",
                        "Channel breakdown",
                        "Cohort data",
                        "Historical trends"
                    ]
                },
                {
                    "step": 2,
                    "name": "Stage Analysis",
                    "per_stage": [
                        "Current metrics",
                        "vs. benchmarks",
                        "Trends",
                        "Health rating"
                    ]
                },
                {
                    "step": 3,
                    "name": "Leak Identification",
                    "identify": [
                        "Biggest drop-offs",
                        "Root causes",
                        "Quick wins",
                        "Long-term fixes"
                    ]
                },
                {
                    "step": 4,
                    "name": "Prioritized Recommendations",
                    "framework": "ICE Score (Impact, Confidence, Ease)",
                    "output": "Ranked action list"
                }
            ]
        }
    ],
