                "OpenAI",
                "Anthropic",
                "Google"
            ]
        }
    },
    "workflows": {
        "standard": [
            {
                "id": "quick-research",
                "duration": "10-15 minutes",
                "iterations": "3-5",
                "sources": "5-10",
                "output": "Brief with citations"
            },
            {
                "id": "deep-dive",
                "duration": "30-60 minutes",
                "pipeline": "Full TTD-DR",
                "sources": "20-50",
                "output": "Comprehensive report"
            },
            {
                "id": "competitive-analysis",
                "focus": "Market landscape",
                "output": "Competitive matrix + insights"
            }
        ],
        "advanced": [
            "literature-review",
            "due-diligence",
            "trend-analysis"
        ]
    },
    "metrics": {
        "quality": {
            "factual_accuracy": "≥90%",
            "citation_coverage": "≥85%",
            "source_diversity": "≥3 types",
            "confidence_score": "≥85%",
            "contradiction_resolution": "100%"
        },
        "efficiency": {
            "quick_research": "<15 min",
            "deep_dive": "<60 min",
            "iterations_to_converge": "≤5",
            "red_team_pass_rate": "≥80%"
        }
    },
    "quality_assurance": {
        "security_gate": {
            "policy": "private_by_default",
            "checks": [
                "no_internal_sensitive_data",
                "api_access_logged"
            ]
        },
        "tracking_gate": {
            "metrics": [
                "denoising_cycles",
                "react_iterations",
                "quality_improvement_rate"
            ]
        },
        "consistency_gate": {
            "rules": [
                "convergence_score >= 0.85",
                "contradictions == 0"
            ]
        }
    },
    "mena_context": {
