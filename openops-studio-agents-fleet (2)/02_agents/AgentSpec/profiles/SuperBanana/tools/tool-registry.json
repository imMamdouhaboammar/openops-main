{
    "internal_tools": [
        {
            "id": "intent-clarifier",
            "name": "Intent Clarifier",
            "stage": 1,
            "category": "understanding",
            "description": "Parses user request into structured visual components",
            "inputs": {
                "user_request": "Raw text request from user",
                "context": "Optional previous conversation context"
            },
            "outputs": {
                "subject": "Primary subject description",
                "action": "What is happening",
                "environment": "Setting/context",
                "style": "Visual aesthetic",
                "mood": "Emotional atmosphere",
                "technical": "Technical specifications",
                "confidence": "Confidence score 0.0-1.0"
            },
            "validation": {
                "metric": "confidence",
                "threshold": 0.9,
                "on_fail": "request_clarification"
            }
        },
        {
            "id": "visual-planner",
            "name": "Visual Planner",
            "stage": 2,
            "category": "planning",
            "description": "Creates detailed visual blueprint for generation",
            "inputs": {
                "intent": "Structured intent from Stage 1"
            },
            "outputs": {
                "composition": {
                    "layout": "Composition rule to use",
                    "focal_point": "X,Y coordinates",
                    "depth_layers": "Foreground/mid/background"
                },
                "lighting": {
                    "source": "Light source type",
                    "direction": "Light direction",
                    "quality": "Hard/soft",
                    "temperature": "Warm/cool/neutral"
                },
                "color": {
                    "palette": "Primary colors",
                    "harmony": "Color harmony type"
                },
                "mood": "Detailed mood description"
            },
            "validation": {
                "metric": "completeness",
                "threshold": 0.95
            }
        },
        {
            "id": "prompt-engineer",
            "name": "Prompt Engineer",
            "stage": 3,
            "category": "crafting",
            "description": "Transforms blueprint into optimized Gemini 3 Pro Image prompt",
            "inputs": {
                "blueprint": "Visual blueprint from Stage 2",
                "intent": "Original intent"
            },
            "outputs": {
                "optimized_prompt": "Final prompt string",
                "technical_layer": "Technical specifications string",
                "style_layer": "Style description string"
            },
            "best_practices": [
                "Use narrative descriptions, not keywords",
                "Include technical camera/lighting specs",
                "Specify style with references",
                "Quote text exactly when needed",
                "Follow 6-part prompt structure"
            ]
        },
        {
            "id": "generation-engine",
            "name": "Generation Engine",
            "stage": 4,
            "category": "execution",
            "description": "Executes image generation via Gemini 3 Pro Image API",
            "inputs": {
                "prompt": "Optimized prompt",
                "config": {
                    "resolution": "Output resolution",
                    "aspect_ratio": "Output aspect ratio",
                    "format": "Output format"
                },
                "references": "Optional reference images (up to 14)"
            },
            "outputs": {
                "image": "Generated image",
                "metadata": "Generation metadata"
            },
            "model": "gemini-3-pro-image-preview",
            "fallback": "gemini-2.5-flash-image"
        },
        {
            "id": "quality-assessor",
            "name": "Quality Assessor",
            "stage": 5,
            "category": "evaluation",
            "description": "Evaluates generated image against original intent",
            "inputs": {
                "image": "Generated image",
                "intent": "Original intent",
                "blueprint": "Visual blueprint"
            },
            "outputs": {
                "overall_score": "Weighted quality score",
                "criteria_scores": {
                    "subject_accuracy": "Score",
                    "composition_match": "Score",
                    "style_fidelity": "Score",
                    "technical_quality": "Score",
                    "text_accuracy": "Score",
                    "mood_atmosphere": "Score"
                },
                "issues": "List of identified issues",
                "verdict": "PASS/CONDITIONAL/FAIL"
            },
            "thresholds": {
                "pass": 0.85,
                "conditional": 0.70,
                "fail": 0.70
            }
        },
        {
            "id": "iterative-refiner",
            "name": "Iterative Refiner",
            "stage": 6,
            "category": "refinement",
            "description": "Improves image when quality check fails",
            "inputs": {
                "assessment": "Quality assessment from Stage 5",
                "original_intent": "Original intent",
                "current_prompt": "Current prompt used"
            },
            "outputs": {
                "refined_prompt": "Improved prompt",
                "action": "REGENERATE or EDIT",
                "strategy": "Refinement strategy used"
            },
            "max_iterations": 3,
            "strategies": [
                "regenerate_with_clearer_subject",
                "add_explicit_composition_guidance",
                "add_style_reference_images",
                "adjust_resolution_and_quality",
                "regenerate_with_quoted_text",
                "adjust_lighting_and_color"
            ]
        },
        {
            "id": "reference-processor",
            "name": "Reference Processor",
            "category": "preprocessing",
            "description": "Processes and optimizes reference images for generation",
            "inputs": {
                "references": "Array of reference images",
                "task_type": "Type of generation task"
            },
            "outputs": {
                "processed_references": "Optimized references (up to 14)",
                "embeddings": "Visual embeddings for consistency",
                "metadata": "Reference metadata"
            },
            "categories": [
                "subject_reference",
                "style_reference",
                "composition_reference",
                "environment_reference",
                "color_reference"
            ]
        },
        {
            "id": "mask-generator",
            "name": "Mask Generator",
            "category": "editing",
            "description": "Generates masks for local edits and inpainting",
            "inputs": {
                "image": "Source image",
                "target": "Description of area to mask"
            },
            "outputs": {
                "mask": "Generated mask image",
                "confidence": "Mask accuracy confidence"
            },
            "mask_types": [
                "subject_isolation",
                "background_selection",
                "region_selection",
                "semantic_selection"
            ]
        },
        {
            "id": "style-analyzer",
            "name": "Style Analyzer",
            "category": "analysis",
            "description": "Analyzes style from reference images",
            "inputs": {
                "reference_image": "Image to analyze"
            },
            "outputs": {
                "style": "Detected style",
                "color_palette": "Extracted colors",
                "lighting": "Lighting characteristics",
                "mood": "Detected mood",
                "keywords": "Style keywords for prompting"
            }
        },
        {
            "id": "consistency-tracker",
            "name": "Consistency Tracker",
            "category": "multi-image",
            "description": "Tracks subject/style consistency across multiple generations",
            "inputs": {
                "subjects": "Array of subject definitions",
                "previous_generations": "Previously generated images"
            },
            "outputs": {
                "consistency_embeddings": "Visual embeddings for consistency",
                "subject_features": "Tracked subject features",
                "style_features": "Tracked style features"
            },
            "max_human_subjects": 5
        },
        {
            "id": "cultural-sensitivity-checker",
            "name": "Cultural Sensitivity Checker",
            "category": "safety",
            "description": "Checks for MENA cultural appropriateness",
            "inputs": {
                "intent": "Planned generation intent",
                "generated_image": "Optional generated image"
            },
            "outputs": {
                "is_appropriate": "Boolean",
                "issues": "List of potential issues",
                "recommendations": "Suggested adjustments"
            },
            "checks": [
                "modesty",
                "religious_sensitivity",
                "cultural_appropriateness",
                "arabic_text_handling"
            ]
        }
    ],
