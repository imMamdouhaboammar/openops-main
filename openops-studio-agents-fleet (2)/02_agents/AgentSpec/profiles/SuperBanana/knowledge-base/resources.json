    "quality_assessment": {
        "criteria": {
            "subject_accuracy": {
                "weight": 0.25,
                "checks": [
                    "correct_subject_type",
                    "matches_description",
                    "proper_positioning",
                    "correct_count"
                ]
            },
            "composition_match": {
                "weight": 0.20,
                "checks": [
                    "follows_blueprint_layout",
                    "correct_depth_layers",
                    "proper_balance",
                    "focal_point_placement"
                ]
            },
            "style_fidelity": {
                "weight": 0.20,
                "checks": [
                    "matches_specified_style",
                    "consistent_aesthetic",
                    "appropriate_mood"
                ]
            },
            "technical_quality": {
                "weight": 0.15,
                "checks": [
                    "resolution_meets_spec",
                    "no_artifacts",
                    "proper_sharpness",
                    "correct_aspect_ratio"
                ]
            },
            "text_accuracy": {
                "weight": 0.10,
                "checks": [
                    "correct_spelling",
                    "proper_font_style",
                    "readable",
                    "well_integrated"
                ]
            },
            "mood_atmosphere": {
                "weight": 0.10,
                "checks": [
                    "matches_intended_emotion",
                    "consistent_lighting_mood",
                    "appropriate_color_mood"
                ]
            }
        },
        "thresholds": {
            "pass": 0.85,
            "conditional": 0.70,
            "fail": 0.70
        }
    },
    "refinement_strategies": {
        "subject_wrong": {
            "strategy": "regenerate_with_clearer_subject",
            "actions": [
                "Make subject description more specific",
                "Add distinguishing characteristics",
                "Specify exact count if multiple"
            ]
        },
        "composition_off": {
            "strategy": "add_explicit_composition_guidance",
            "actions": [
                "Specify composition rule explicitly",
                "Add focal point coordinates",
                "Describe relative positioning"
            ]
        },
        "style_mismatch": {
            "strategy": "add_style_reference_images",
            "actions": [
                "Include style reference images",
                "Strengthen style keywords",
                "Reference specific artists/styles"
            ]
        },
        "technical_issues": {
            "strategy": "adjust_resolution_and_quality",
            "actions": [
                "Explicitly specify resolution",
                "Add quality keywords (sharp, detailed)",
                "Check aspect ratio specification"
            ]
        },
        "text_errors": {
            "strategy": "regenerate_with_quoted_text",
            "actions": [
                "Quote text exactly in prompt",
                "Specify font style explicitly",
                "Reduce text length if complex"
            ]
        },
        "mood_wrong": {
            "strategy": "adjust_lighting_and_color",
            "actions": [
                "Revise lighting description",
                "Adjust color temperature words",
                "Add emotional atmosphere keywords"
            ]
        }
    },
