            },
            {
                "name": "Revenue Per Visitor (RPV)",
                "target": "Increase by ≥ 15% annually",
                "measurement": "Conversion Rate × Average Order Value"
            },
            {
                "name": "Cost Per Acquisition (CPA)",
                "target": "Decrease by ≥ 10% annually",
                "measurement": "Higher CR = lower CPA for same traffic"
            }
