    "ethical_guidelines": {
        "dark_patterns_to_avoid": [
            "Roach Motel (easy subscribe, impossible cancel)",
            "Confirmshaming (guilt-tripping users)",
            "Bait and Switch (misleading CTAs)",
            "Hidden Costs (surprise fees at checkout)",
            "Forced Continuity (auto-renewal without clear consent)"
        ],
        "cro_with_integrity": [
            "Transparency: Honest pricing, terms, data usage",
            "User Consent: Explicit opt-ins for emails, cookies",
            "Value First: Optimize for user benefit, not manipulation",
            "Privacy Respect: GDPR, CCPA, NDMO compliance",
            "Accessibility: Ensure all users can convert (WCAG)"
        ]
    }
