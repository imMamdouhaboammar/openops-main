  "workflow_system": {
    "standard_process": {
      "phase_1_research": {
        "duration": "Day 1",
        "objective": "Deep audience and context understanding",
        "deliverables": ["research_sheet", "audience_emotional_map", "umdp_framework_completion"],
        "framework": "U-M-D-B-P (User-Moment-Desire-Block-Proof)",
        "outputs": [
          "user_persona_detailed",
          "psychological_state_analysis",
          "desire_vs_fear_map",
          "barrier_identification",
          "proof_requirements"
        ]
      },
      
      "phase_2_messaging_architecture": {
        "duration": "Day 2",
        "objective": "Structure message before writing copy",
        "deliverables": ["messaging_sheet", "message_hierarchy", "core_promise"],
        "components": [
          "core_promise_definition",
          "supporting_arguments",
          "doubt_handling",
          "objection_killers",
          "social_reinforcement",
          "why_now_logic"
        ]
      },
      
      "phase_3_drafting": {
        "duration": "Day 3",
        "objective": "Write ugly first draft without editing",
        "rules": [
          "one_idea_per_line",
          "conversational_tone",
          "no_stopping_for_perfection",
          "reach_80_percent_completion"
        ]
      },
      
      "phase_4_rewriting": {
        "duration": "Day 4",
        "objective": "Polish through 5 filters",
        "filters": [
          "clarity_filter",
          "tightening_filter",
          "transition_filter",
          "emotional_lift_filter",
          "voice_consistency_filter"
        ]
      },
      
      "phase_5_proof_layering": {
        "duration": "Day 5",
        "objective": "Add trust elements strategically",
        "proof_types": [
          "social_proof",
          "statistical_proof",
          "authority_proof",
          "transformation_stories",
          "guarantees"
        ]
      },
      
      "phase_6_crx_optimization": {
        "duration": "Day 6",
        "objective": "Optimize user experience and flow",
        "tests": [
          "7_second_test",
          "momentum_test",
          "mobile_readability",
          "cta_logic_check"
        ]
      },
      
      "phase_7_publish_measure": {
        "duration": "Day 7",
        "objective": "Launch and monitor performance",
        "activities": [
          "ab_variant_creation",
          "metrics_tracking_setup",
          "performance_monitoring",
          "iteration_planning"
        ]
      }
    },
    
    "quick_mode": {
      "description": "Compressed workflow for urgent requests",
      "duration": "2-4 hours",
      "phases": ["research_brief", "framework_selection", "draft_polish", "proof_integration"]
    },
    
    "consultation_mode": {
      "description": "Advisory role for existing copy review",
      "deliverables": ["copy_audit", "improvement_recommendations", "rewrite_suggestions"]
    }
  },

  "quality_gates": {
    "pre_delivery_checklist": {
      "clarity_check": "Can a 12-year-old understand it?",
      "relevance_check": "Does it speak directly to target persona?",
      "trust_check": "Is there proof to support claims?",
      "safety_check": "Does it reduce perceived risk?",
      "reward_check": "Is the value clear and compelling?",
      "momentum_check": "Does it flow smoothly without friction?",
      "cta_check": "Is the next step obvious and low-risk?"
    },
    
    "five_filters_system": {
      "filter_1_clarity": "Is it immediately understandable?",
      "filter_2_relevance": "Does customer see themselves in it?",
      "filter_3_trust": "Is it believable and provable?",
      "filter_4_safety": "Does it reduce fear and risk?",
      "filter_5_effort_vs_reward": "Is the ROI obvious?"
    }
